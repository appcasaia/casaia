# Clave de la API de Anthropic (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clave de Resend para el envío de emails de leads (resend.com -> API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# A qué email querés que lleguen los leads
LEAD_EMAIL_TO=casaia24h@gmail.com

# Desde qué email se envían (tiene que ser un dominio verificado en Resend,
# o usar onboarding@resend.dev mientras probás)
LEAD_EMAIL_FROM=notificaciones@casaia.net

# Base de datos Upstash Redis para guardar métricas (upstash.com, plan gratis)
KV_REST_API_URL=https://tu-base.upstash.io
KV_REST_API_TOKEN=tu-token-de-upstash

# Clave secreta que vos elegís para entrar a /panel (métricas de uso).
# Inventá cualquier contraseña larga, no hace falta que la registres en ningún lado.
ADMIN_SECRET=elegí-una-clave-larga-y-secreta

# No hacen falta variables nuevas para técnicos/inmobiliarias: reutilizan
# la misma base de datos (KV_REST_API_URL/TOKEN) y el mismo email (Resend).

# Cloudflare Turnstile (protección anti-bots en formularios públicos).
# Site Key es pública (va al navegador), Secret Key es privada (va al servidor).
# Sacá las dos en dash.cloudflare.com -> Turnstile -> tu sitio.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x............................
TURNSTILE_SECRET_KEY=0x............................
